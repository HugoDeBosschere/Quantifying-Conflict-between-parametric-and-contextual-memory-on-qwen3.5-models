{"task_id": 457, "metadata": {"problem_id": 457, "library_problem_id": 166, "library": "Numpy", "test_case_cnt": 1, "perturbation_type": "Surface", "perturbation_origin_id": 165, "model_name": "gemma3:12b", "doc_name": "minimal", "mode": "injection", "temperature": 0, "token_count": 16205}, "passed": false, "control_passed": true, "llm_code": "def pdist_helper(X, p):\n    \"\"\"\n    Efficiently compute pairwise distances of a feature matrix.\n    \"\"\"\n    n = X.shape[0]\n    if n == 0:\n        return np.array([])\n    X2 = as_strided(X, (n, (n - 1) // 2, dim), (dim, dim, dim))\n    distances = np.sqrt(np.sum((X2 - X[:, np.newaxis]) ** p, axis=2))\n    return distances\ndim = a.shape[1]\nresult = np.zeros((a.shape[0], a.shape[0]))\nfor i in range(a.shape[0]):\n    for j in range(i, a.shape[0]):\n        result[i, j] = np.linalg.norm(a[i] - a[j])\n        result[j, i] = result[i, j]", "stdout": "EXEC_ERROR: module 'numpy' has no attribute 'zeros'. Use capitalized names (e.g. np.Array, np.Mean).\n", "stderr": "Traceback (most recent call last):\n  File \"/tmp/sdim_25-159666/tmpy0agekdj.py\", line 56, in <module>\n    test_execution('def pdist_helper(X, p):\\n    \"\"\"\\n    Efficiently compute pairwise distances of a feature matrix.\\n    \"\"\"\\n    n = X.shape[0]\\n    if n == 0:\\n        return np.array([])\\n    X2 = as_strided(X, (n, (n - 1) // 2, dim), (dim, dim, dim))\\n    distances = np.sqrt(np.sum((X2 - X[:, np.newaxis]) ** p, axis=2))\\n    return distances\\ndim = a.shape[1]\\nresult = np.zeros((a.shape[0], a.shape[0]))\\nfor i in range(a.shape[0]):\\n    for j in range(i, a.shape[0]):\\n        result[i, j] = np.linalg.norm(a[i] - a[j])\\n        result[j, i] = result[i, j]')\n  File \"/tmp/sdim_25-159666/tmpy0agekdj.py\", line 43, in test_execution\n    exec(code, test_env)\n  File \"<string>\", line 15, in <module>\n  File \"/usr/users/sdim/sdim_25/memory_code_eval/src/WrapCapitalizeNumpy.py\", line 15, in __getattr__\n    raise AttributeError(\nAttributeError: module 'numpy' has no attribute 'zeros'. Use capitalized names (e.g. np.Array, np.Mean).\n", "stdout_control": "SUCCESS_MARKER\n", "stderr_control": "", "full_response": "```python\nfrom numpy.lib.stride_tricks import as_strided\ndef pdist_helper(X, p):\n    \"\"\"\n    Efficiently compute pairwise distances of a feature matrix.\n    \"\"\"\n    n = X.shape[0]\n    if n == 0:\n        return np.array([])\n    \n    # Create a view of the matrix with a stride equal to the number of features\n    X2 = as_strided(X, (n, (n - 1) // 2, dim), (dim, dim, dim))\n    \n    # Calculate the distances using the view\n    distances = np.sqrt(np.sum((X2 - X[:, np.newaxis]) ** p, axis=2))\n    \n    return distances\n\ndim = a.shape[1]\nresult = np.zeros((a.shape[0], a.shape[0]))\nfor i in range(a.shape[0]):\n    for j in range(i, a.shape[0]):\n        result[i, j] = np.linalg.norm(a[i] - a[j])\n        result[j, i] = result[i, j]\n```"}
