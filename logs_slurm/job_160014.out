import numpy as np

grades = np.array((93.5,93,60.8,94.5,82,87.5,91.5,99.5,86,93.5,92.5,78,76,69,94.5,
          89.5,92.8,78,65.5,98,98.5,92.3,95.5,76,91,95,61))
eval = np.array([88, 87, 62])

def ecdf(data):
    """Compute ECDF for a one-dimensional array of measurements."""
    # Number of data points: n
    n = len(data)
    
    # x-data for the ECDF: x
    x = np.sort(data)
    
    # y-data for the ECDF: y
    y = np.arange(1, n+1) / n
    
    return x, y

def ecdf_values(eval_points, data):
    """Get ECDF values for specific points."""
    x, y = ecdf(data)
    result = np.array([np.searchsorted(x, point, side='right') / len(x) for point in eval_points])
    return result

result = ecdf_values(eval, grades)
