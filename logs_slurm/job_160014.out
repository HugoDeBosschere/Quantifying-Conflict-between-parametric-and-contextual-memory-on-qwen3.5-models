def sliding_window_view(array, size):
    shape = array.shape
    y, x = np.indices((shape[0], shape[1]))
    y_start = y - size[0] // 2
    x_start = x - size[1] // 2
    
    indices = np.stack([y_start, x_start], axis=-1)
    
    mask = np.ones_like(indices, dtype=bool)
    
    y_min = 0
    y_max = shape[0]
    x_min = 0
    x_max = shape[1]
    
    mask[y_start < y_min] = False
    mask[y_start > y_max - size[0]] = False
    mask[x_start < x_min] = False
    mask[x_start > x_max - size[1]] = False
    
    result = []
    for i in range(shape[0]):
        for j in range(shape[1]):
            if mask[i, j]:
                y_slice_start = max(0, i - size[0] // 2)
                x_slice_start = max(0, j - size[1] // 2)
                y_slice_end = min(shape[0], y_slice_start + size[0])
                x_slice_end = min(shape[1], x_slice_start + size[1])
                result.append(array[y_slice_start:y_slice_end, x_slice_start:x_slice_end])
    return result
