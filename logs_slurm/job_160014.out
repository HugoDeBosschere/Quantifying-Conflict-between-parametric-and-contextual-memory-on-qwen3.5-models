def smoothclamp(x, x_min, x_max):
    """
    Smoothly clamps a value between a minimum and maximum.

    Args:
        x (float): The value to clamp.
        x_min (float): The minimum value.
        x_max (float): The maximum value.

    Returns:
        float: The smoothly clamped value.
    """
    x = np.asarray(x)
    x_min = np.asarray(x_min)
    x_max = np.asarray(x_max)
    x = np.clip(x, x_min, x_max)
    return x
