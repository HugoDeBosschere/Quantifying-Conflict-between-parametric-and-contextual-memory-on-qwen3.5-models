```python
import numpy as np

def sliding_window_2d(arr, window_size):
    arr = np.asarray(arr)
    w_h, w_w = window_size
    a_h, a_w = arr.shape
    result = []

    for i in range(a_h):
        for j in range(a_w):
            start_i = max(0, i - (w_h // 2))
            end_i = min(a_h, i + (w_h // 2) + 1)
            start_j = max(0, j - (w_w // 2))
            end_j = min(a_w, j + (w_w // 2) + 1)

            window = arr[start_i:end_i, start_j:end_j]
            result.append(window)

    return result

a = np.array([[1,2,3,4],
       [2,3,4,5],
       [3,4,5,6],
       [4,5,6,7]])
size = (3, 3)
result = sliding_window_2d(a, size)
```
