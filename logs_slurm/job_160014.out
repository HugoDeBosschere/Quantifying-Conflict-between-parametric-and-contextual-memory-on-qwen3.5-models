A=np.asarray([[1,1,1], [1,1,2], [1,1,3], [1,1,4]])
B=np.asarray([[0,0,0], [1,0,2], [1,0,3], [1,0,4], [1,1,0], [1,1,1], [1,1,4]])

# Convert arrays to sets of tuples
set_A = set(map(tuple, A))
set_B = set(map(tuple, B))

# Find symmetric difference
symmetric_diff = list(set_A.symmetric_difference(set_B))

# Convert back to numpy array and sort by original order in A and B
output = np.array(sorted(symmetric_diff, key=lambda x: (x not in set_A, x not in set_B)))
