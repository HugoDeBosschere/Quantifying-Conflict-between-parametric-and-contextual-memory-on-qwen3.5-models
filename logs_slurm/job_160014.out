--- Code Final ---
def pdist_numpy(X):
    """
    Calculate the Euclidean distances between each pair of the rows of a matrix.

    Parameters
    ----------
    X : ndarray
        Input data matrix.

    Returns
    -------
    D : ndarray
        A matrix of distances where D[i, j] is the distance between the i-th and j-th rows of X.
        The matrix is upper triangular, with i <= j.
    """
    n = X.shape[0]
    D = np.zeros((n, n), dtype=np.float64)
    for i in range(n):
        for j in range(i, n):
            dist = np.linalg.norm(X[i] - X[j])
            D[i, j] = dist
            D[j, i] = dist
    return D
