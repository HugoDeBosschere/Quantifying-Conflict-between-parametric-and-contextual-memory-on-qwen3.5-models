def smoothstep(x, x_min, x_max, N):
    if x < x_min:
        return x_min
    elif x > x_max:
        return x_max
    else:
        t = (x - x_min) / (x_max - x_min)
        return x_min + (x_max - x_min) * (t ** N * (N * (1 - t) + t))
