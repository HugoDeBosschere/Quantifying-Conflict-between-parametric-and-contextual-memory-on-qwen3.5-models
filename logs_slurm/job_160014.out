n2 = [6, 7, 8, 9, 10]

# Iterate over each row and apply the conditions using boolean indexing
for i in range(arr.shape[0]):
    mask_less_than_n1 = arr[i] < n1[i]
    mask_greater_equal_n2 = arr[i] >= n2[i]
    mask_between_n1_and_n2 = ~mask_less_than_n1 & ~mask_greater_equal_n2

    arr[i, mask_less_than_n1] = 0
    arr[i, mask_between_n1_and_n2] += 5
    arr[i, mask_greater_equal_n2] = 30

# The modified array is now stored in 'arr'
