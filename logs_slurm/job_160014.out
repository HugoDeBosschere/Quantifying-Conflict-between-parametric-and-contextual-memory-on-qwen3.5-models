import numpy as np

def zero_pad_array(arr, target_shape):
    rows_to_add = (target_shape[0] - arr.shape[0]) // 2 + (target_shape[0] - arr.shape[0]) % 2
    cols_to_add = (target_shape[1] - arr.shape[1]) // 2 + (target_shape[1] - arr.shape[1]) % 2

    top_pad = rows_to_add // 2
    bottom_pad = rows_to_add - top_pad
    left_pad = cols_to_add // 2
    right_pad = cols_to_add - left_pad

    return np.pad(arr, ((top_pad, bottom_pad), (left_pad, right_pad)), mode='constant', constant_values=0)

