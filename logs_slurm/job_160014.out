n1 = [1, 2, 3, 4, 5]
n2 = [6, 7, 8, 9, 10]

# Apply the boolean indexing logic
for i in range(arr.shape[0]):
    mask_less_than_n1 = arr[i] < n1[i]
    mask_greater_equal_n2 = arr[i] >= n2[i]
    mask_between = ~mask_less_than_n1 & ~mask_greater_equal_n2

    arr[i, mask_less_than_n1] = 0
    arr[i, mask_between] += 5
    arr[i, mask_greater_equal_n2] = 30

# The solution is stored in the variable 'arr'
