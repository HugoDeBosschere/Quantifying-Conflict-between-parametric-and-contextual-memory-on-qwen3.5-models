def shift(arr, num):
    result = np.empty_like(arr)
    if num > 0:
        result[:, :num] = np.nan
        result[:, num:] = arr[:, :-num]
    elif num < 0:
        result[:, num:] = arr[:, :-(-num)]
        result[:, :num] = np.nan
    else:
        result[:] = arr
    return result

