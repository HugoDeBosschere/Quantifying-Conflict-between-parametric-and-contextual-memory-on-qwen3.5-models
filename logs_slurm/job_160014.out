def circular_correlation(a, b):
    n = len(a)
    padded_b = np.pad(b, (0, n), 'wrap')
    correlation = np.zeros(n)
    for lag in range(n):
        correlation[lag] = np.sum(a * padded_b[lag:])
    return correlation

result = circular_correlation(a, b)
