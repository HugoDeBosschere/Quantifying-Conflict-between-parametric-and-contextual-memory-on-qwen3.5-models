import numpy as np

a = np.array([[1,2],[3,4]])
pos = [1, 2]
element = np.array([[3, 5], [6, 6]])

# Create a new array to hold the result
result = np.zeros((len(a) + len(element), a.shape[1]), dtype=a.dtype)

# Copy elements from 'a' into 'result', skipping positions where we will insert 'element'
current_pos_a = 0
current_pos_result = 0

for i in range(len(result)):
    if current_pos_a < len(pos) and i == pos[current_pos_a]:
        # Insert element row at the specified position
        result[i] = element[current_pos_a]
        current_pos_a += 1
    else:
        # Copy from 'a'
        result[i] = a[current_pos_result]
        current_pos_result += 1

a = result
