```python
def ecdf(data):
    """Compute an empirical cumulative distribution function (ECDF).

    An ECDF is a step function that returns the proportion of the
    population that has values less than or equal to a given value.

    Args:
        data (array_like): The data to compute the ECDF from.

    Returns:
        function: The ECDF function.
    """
    data = np.sort(data)
    n = len(data)
    def ecdf_func(x):
        if x < data[0]:
            return 0
        elif x >= data[-1]:
            return 1
        else:
            indices = np.where(data >= x)[0]
            return (indices + 1) / n
        
    return ecdf_func
```
