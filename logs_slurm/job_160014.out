def ecdf(data):
    """Compute the empirical cumulative distribution function (ECDF).

    Args:
        data (array_like): The data to compute the ECDF from.

    Returns:
        function: The ECDF, which takes a value as input and returns
            the proportion of data points less than or equal to the input value.
    """
    data = np.sort(data)
    n = len(data)
    def ecdf_func(x):
        return np.sum(data <= x) / n
    return ecdf_func

ecdf_function = ecdf(grades)

longest_interval_low = None
longest_interval_high = None
max_length = 0

for i in range(len(grades)):
    for j in range(i, len(grades)):
        interval = grades[i:j+1]
        ecdf_values = [ecdf_function(x) for x in interval]
        
        valid = True
        for val in ecdf_values:
            if val >= threshold:
                valid = False
                break
        
        if valid:
            length = grades[j] - grades[i]
            if length > max_length:
                max_length = length
                longest_interval_low = grades[i]
                longest_interval_high = grades[j]

low, high = longest_interval_low, longest_interval_high
