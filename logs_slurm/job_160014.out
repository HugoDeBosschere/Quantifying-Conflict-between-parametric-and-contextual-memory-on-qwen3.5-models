def sliding_window_view(array, size):
    shape = array.shape
    (y, x) = np.indices((shape[0], shape[1]))
    y_start = y - size[0] // 2
    x_start = x - size[1] // 2
    indices = np.stack([y_start, x_start], axis=-1)
    result = []
