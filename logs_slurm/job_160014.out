        for j in range(shape[1]):
            start_y = i - size[0] // 2
            start_x = j - size[1] // 2
            end_y = start_y + size[0]
            end_x = start_x + size[1]
            valid_indices = np.where((start_y >= 0) & (start_y < shape[0]) & (start_x >= 0) & (start_x < shape[1]))
            if len(valid_indices[0]) > 0:
                window = array[start_y:end_y, start_x:end_x]
