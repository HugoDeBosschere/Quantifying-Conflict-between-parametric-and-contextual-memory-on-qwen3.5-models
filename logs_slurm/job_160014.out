# Find indices where ecdf is less than threshold
indices = np.where(ecdf < threshold)[0]

# If no such indices exist, return None for low and high
if len(indices) == 0:
    low, high = None, None
else:
    # Get the lowest index where ecdf is less than threshold
    low_index = np.min(indices)

    # Get the highest index where ecdf is less than threshold and it's not the last element in grades_sorted
    high_index = np.max(indices) + 1 if np.max(indices) < len(grades_sorted) - 1 else None

    # If high_index is None, it means that all elements satisfy ECDF(x) < threshold, so we take the whole array
    if high_index is None:
        low, high = grades_sorted[0], grades_sorted[-1] + 1
