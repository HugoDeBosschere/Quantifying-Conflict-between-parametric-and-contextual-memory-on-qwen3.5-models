```python
def sliding_window_view(array, size):
    shape = array.shape
    y, x = np.indices((shape[0], shape[1]))
    y_start = y - size[0] // 2
    x_start = x - size[1] // 2
    
    indices = np.stack([y_start, x_start], axis=-1)
    
    result = []
    for i in range(shape[0]):
        for j in range(shape[1]):
            start_y = i - size[0] // 2
            start_x = j - size[1] // 2
            
            end_y = start_y + size[0]
            end_x = start_x + size[1]
            
            valid_indices = np.where(
                (start_y >= 0) & (start_y < shape[0]) &
                (start_x >= 0) & (start_x < shape[1])
            )
            
            if len(valid_indices[0]) > 0:
                window = array[start_y:end_y, start_x:end_x]
                result.append(window)
    return result
result = sliding_window_view(a, size)
