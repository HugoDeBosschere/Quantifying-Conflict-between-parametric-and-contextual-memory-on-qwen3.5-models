def circular_correlation(a, b):
    n = len(a)
    padded_b = np.pad(b, (0, n), 'wrap')
    correlations = np.zeros(n)
    for lag in range(n):
        correlation = np.sum(a * padded_b[lag:])
        correlations[lag] = correlation
    return correlations

