```python
def ecdf(x):
    """
    Calculates the empirical cumulative distribution function (ECDF) for a given array.

    Args:
        x (numpy.ndarray): The input array.

    Returns:
        function: A function that takes a value as input and returns the ECDF value at that point.
    """
    x = np.sort(x)
    n = len(x)
    def ecdf_func(val):
        if val < x[0]:
            return 0
        elif val > x[-1]:
            return 1
        else:
            idx = np.searchsorted(x, val)
            return (idx) / n
    return ecdf_func

