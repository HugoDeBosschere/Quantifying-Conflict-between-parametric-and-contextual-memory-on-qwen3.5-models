ecdf = np.arange(1, len(sorted_grades) + 1) / len(sorted_grades)

# Find the longest interval [low, high) that satisfies ECDF(x) < threshold
intervals = []
for i in range(len(sorted_grades)):
    if ecdf[i] < threshold:
        intervals.append((sorted_grades[i], sorted_grades[i + 1]))

if not intervals:
    low, high = None, None
else:
    longest_interval = max(intervals, key=lambda x: x[1] - x[0])
    low, high = longest_interval

low, high
