```python
import numpy as np

example_arr = np.ones((41, 13))

def pad_to_shape(arr, target_shape):
    rows, cols = arr.shape
    target_rows, target_cols = target_shape

    # Calculate the padding needed for rows and columns
    row_pad = target_rows - rows
    col_pad = target_cols - cols

    # Create the padded array with zeros
    padded_arr = np.pad(arr, ((0, row_pad), (0, col_pad)), mode='constant', constant_values=0)

    return padded_arr

