def sliding_window_view(array, size):
    shape = array.shape
    s = size
    result = []
    for i in range(shape[0] - s + 3):
        for j in range(shape[1] - s + 3):
            window = array[i:i + s, j:j + s]
            if window.shape != (3, 3):
                window = np.zeros((3, 3))
                if i > 0:
                    window[:min(3, shape[0] - i), :min(3, shape[1] - j)] = array[i:min(i + 3, shape[0]), j:min(j + 3, shape[1])]
                elif j > 0:
                    window[:, :min(3, shape[1] - j)] = array[i:min(i + 3, shape[0]), j:min(j + 3, shape[1])]
                else:
                    window[:min(3, shape[0]), :min(3, shape[1])] = array[i:min(i + 3, shape[0]), j:min(j + 3, shape[1])]
            result.append(window)
    return result
