def simpson_2d(f, x, y):
    """
    Perform a 2D integral using Simpson's rule.
    f: function to integrate
    x: array of x values
    y: array of y values
    """
    (X, Y) = np.meshgrid(x, y)
    Z = f(X, Y)
    hx = (x[-1] - x[0]) / (len(x) - 1)
    hy = (y[-1] - y[0]) / (len(y) - 1)
    integral = 0
    for i in range(len(x) - 2):
        for j in range(len(y) - 2):
            integral += hx * hy / 9 * (f(x[i], y[j]) + f(x[i + 2], y[j]) + 4 * (f(x[i + 1], y[j]) + f(x[i + 1], y[j + 2])) + 16 * f(x[i + 1], y[j + 1]))
    return integral

def integrand(X, Y):
    return np.cos(X) ** 4 + np.sin(Y) ** 2
result = simpson_2d(integrand, x, y)
