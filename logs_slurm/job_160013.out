def sliding_window(arr, window_size):
    rows, cols = arr.shape
    wr, wc = window_size

    result = []
    for i in range(rows):
        for j in range(cols):
            r_start = max(0, i - wr // 2)
            c_start = max(0, j - wc // 2)
            r_end = min(rows, i + wr // 2 + 1)
            c_end = min(cols, j + wc // 2 + 1)

            window = arr[r_start:r_end, c_start:c_end]
            result.append(window)

    return result

