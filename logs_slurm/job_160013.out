def sliding_window_2d(arr, window_size):
    (h, w) = arr.shape
    (wh, ww) = window_size
    result = []
    for i in range(h):
        for j in range(w):
            start_i = max(0, i - wh // 2)
            end_i = min(h, i + wh // 2 + 1)
            start_j = max(0, j - ww // 2)
            end_j = min(w, j + ww // 2 + 1)
            window = arr[start_i:end_i, start_j:end_j]
            result.append(window)
    return result
result = sliding_window_2d(a, size)
for window in result:
    print(window)
