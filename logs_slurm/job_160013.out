import numpy as np

# Given arrays and positions
a = np.array([[1,2],[3,4]])
pos = [1, 2]
element = np.array([[3, 5], [6, 6]])

# Create a new array with the required shape to hold all elements including inserted ones
result = np.zeros((len(a) + len(element), a.shape[1]), dtype=a.dtype)

# Copy original elements into result array while skipping positions where we will insert new elements
j = 0
for i in range(len(result)):
    if j < len(pos) and i == pos[j]:
        # Insert element at the current position
        result[i] = element[j]
        j += 1
    else:
        # Copy original array element to the result array
        result[i] = a[len(a[:i]) - (len(result[:i]) - len(pos[:j]))]

a = result
