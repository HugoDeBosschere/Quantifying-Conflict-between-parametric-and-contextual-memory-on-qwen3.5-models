arrays = [np.ones((41, 13)), np.ones((50, 12)), ...]
shape = (93, 13)

padded_arrays = []
for array in arrays:
    padded_array = np.pad(array, ((0, shape[0] - array.shape[0]), (0, shape[1] - array.shape[1])), mode='constant')
    padded_arrays.append(padded_array)
</code>

