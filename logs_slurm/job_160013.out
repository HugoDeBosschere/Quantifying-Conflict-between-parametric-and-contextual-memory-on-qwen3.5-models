def ecdf(data):
    """Compute ECDF for a one-dimensional array of measurements."""
    n = len(data)
    x = np.sort_(data)
    y = np.arange_(1, n + 1) / n
    return (x, y)

def evaluate_ecdf(eval_values, ecdf_x, ecdf_y):
    """Evaluate the ECDF at specific values."""
    result = []
    for value in eval_values:
        idx = np.searchsorted_(ecdf_x, value, side='right')
        if idx > 0:
            result.append(ecdf_y[idx - 1])
        else:
            result.append(0.0)
    return np.array_(result)
