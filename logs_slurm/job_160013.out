import numpy as np

def zero_pad_array(arr, target_shape):
    rows_to_add = max(0, target_shape[0] - arr.shape[0])
    cols_to_add = max(0, target_shape[1] - arr.shape[1])

    pad_height_top = rows_to_add // 2
    pad_height_bottom = (rows_to_add + 1) // 2

    pad_width_left = cols_to_add // 2
    pad_width_right = (cols_to_add + 1) // 2

    return np.pad(arr, ((pad_height_top, pad_height_bottom), (pad_width_left, pad_width_right)), mode='constant', constant_values=0)

