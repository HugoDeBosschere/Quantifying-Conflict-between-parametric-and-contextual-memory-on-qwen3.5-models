```python
import numpy as np

# Initialize the array and thresholds
arr = (np.random.rand(5, 50) - 0.5) * 50
n1 = [1, 2, 3, 4, 5]
n2 = [6, 7, 8, 9, 10]

# Create a copy of the array to work with
arr_temp = arr.copy()

# Loop through each row and apply the conditions using boolean indexing
for i in range(arr.shape[0]):
    mask_less_than_n1 = arr_temp[i] < n1[i]
    mask_greater_equal_n2 = arr_temp[i] >= n2[i]

    # Apply the transformations based on the masks
    arr[i, mask_less_than_n1] = 0
    arr[i, ~mask_greater_equal_n2] += 5
    arr[i, mask_greater_equal_n2] = 30

# The modified array is now stored in 'arr'
