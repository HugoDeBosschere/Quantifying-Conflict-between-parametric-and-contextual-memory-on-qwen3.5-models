import numpy as np

a = np.array([[1,2],[3,4]])
pos = [1, 2]
element = np.array([[3, 5], [6, 6]])

# Create a new array with the required size
result = np.zeros((len(a) + len(element), a.shape[1]), dtype=a.dtype)

# Copy elements from 'a' to 'result', skipping positions where we will insert 'element'
i, j = 0, 0
for k in range(len(result)):
    if i < len(pos) and k == pos[i]:
        result[k] = element[j]
        j += 1
        i += 1
    else:
        result[k] = a[j]

a = result
