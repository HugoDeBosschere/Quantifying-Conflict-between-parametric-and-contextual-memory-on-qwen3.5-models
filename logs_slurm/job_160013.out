import numpy as np

def moving_window_2d(arr, window_shape):
    arr_shape = arr.shape
    window_height, window_width = window_shape

    result = []
    for i in range(arr_shape[0]):
        for j in range(arr_shape[1]):
            row_start = max(0, i - (window_height // 2))
            row_end = min(arr_shape[0], i + (window_height // 2) + 1)
            col_start = max(0, j - (window_width // 2))
            col_end = min(arr_shape[1], j + (window_width // 2) + 1)

            window = arr[row_start:row_end, col_start:col_end]
            result.append(window)

