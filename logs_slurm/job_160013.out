import numpy as np

def sliding_window(arr, window_size):
    rows, cols = arr.shape
    win_rows, win_cols = window_size
    result = []

    for i in range(rows):
        for j in range(cols):
            r_start = max(0, i - (win_rows // 2))
            c_start = max(0, j - (win_cols // 2))
            r_end = min(rows, i + (win_rows // 2) + 1)
            c_end = min(cols, j + (win_cols // 2) + 1)

            window = arr[r_start:r_end, c_start:c_end]
            result.append(window)

    return result

result = sliding_window(a, size)
```
---------------------------

--- Code Final ---
def sliding_window(arr, window_size):
    (rows, cols) = arr.shape
    (win_rows, win_cols) = window_size
    result = []
    for i in range(rows):
        for j in range(cols):
            r_start = max(0, i - win_rows // 2)
            c_start = max(0, j - win_cols // 2)
            r_end = min(rows, i + win_rows // 2 + 1)
            c_end = min(cols, j + win_cols // 2 + 1)
