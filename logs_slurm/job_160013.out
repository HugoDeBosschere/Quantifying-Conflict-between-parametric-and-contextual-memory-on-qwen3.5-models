    jmin, jmax = 0, arr.shape[1] - window_size[1]

    windows = []
    for i in range(imin, imax + 1):
        for j in range(jmin, jmax + 1):
            window = arr[i:i+window_size[0], j:j+window_size[1]]
            windows.append(window)

    return windows

result = sliding_window(a, size)
