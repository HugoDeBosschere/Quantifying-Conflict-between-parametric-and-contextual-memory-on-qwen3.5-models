def ecdf(x):
    """
    Compute the empirical cumulative distribution function (ECDF).

    Args:
        x (array_like): The data to compute the ECDF from.

    Returns:
        function: The ECDF, which takes a value and returns the proportion of
            data less than or equal to that value.
    """
    x = np.sort(x)
    n = len(x)
    def ecdf_func(val):
        if val < x[0]:
            return 0
        if val >= x[-1]:
            return 1
        idx = np.searchsorted(x, val)
        return float(idx) / n
    return ecdf_func

ecdf_func = ecdf(grades)

