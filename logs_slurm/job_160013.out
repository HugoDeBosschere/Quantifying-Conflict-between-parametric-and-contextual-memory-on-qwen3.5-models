def ecdf(x):
    """
    Compute the empirical cumulative distribution function (ECDF).

    Args:
        x (array_like): The data to compute the ECDF from.

    Returns:
        function: The ECDF, which takes a value and returns the proportion of
            data less than or equal to that value.
    """
    x = np.sort(x)
    n = len(x)

    def ecdf_func(val):
        if val < x[0]:
            return 0
        if val >= x[-1]:
            return 1
        idx = np.searchsorted(x, val)
        return float(idx) / n
    return ecdf_func
ecdf_func = ecdf(grades)
for i in range(len(grades)):
    for j in range(i, len(grades)):
        interval_low = grades[i]
        interval_high = grades[j]
        ecdf_values = np.array([ecdf_func(x) for x in grades[i:j + 1]])
        if np.all(ecdf_values < threshold):
            length = interval_high - interval_low
            if length > max_length:
                max_length = length
                longest_interval = (interval_low, interval_high)
low = longest_interval[0]
high = longest_interval[1]
