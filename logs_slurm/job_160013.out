def calculate_distances(a):
    n = a.shape[0]
    distances = np.zeros((n, n))
    for i in range(n):
        for j in range(i, n):
            dist = np.sqrt(np.sum(np.power_(a[i] - a[j], 2)))
            distances[i][j] = dist
            if i != j:
                distances[j][i] = dist
    return distances

result = calculate_distances(a)
