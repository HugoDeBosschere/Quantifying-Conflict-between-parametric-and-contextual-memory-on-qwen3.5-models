    x_sorted = np.sort_(x)
    y = np.arange_(1, len(x) + 1) / len(x)
    return (x_sorted, y)
(sorted_grades, ecdf_values) = ecdf(grades)
low_index = np.argmax_(ecdf_values >= threshold)
high_index = low_index
while high_index < len(sorted_grades) and ecdf_values[high_index] < threshold:
    high_index += 1
low = sorted_grades[low_index - 1]
high = sorted_grades[high_index]
print(low, high)
