def ecdf(data):
    """Compute an empirical cumulative distribution function (ECDF).

    Args:
        data: A 1-dimensional array of numerical data.

    Returns:
        A function that takes a single numerical value as input and
        returns the ECDF value at that point.
    """
    data_sorted = np.sort(data)
    n = len(data)

    def ecdf_function(x):
        if x < data_sorted[0]:
            return 0
        elif x > data_sorted[-1]:
            return 1
        else:
            index = np.searchsorted(data_sorted, x)
            return index / n
    return ecdf_function
