def sliding_window(a, window):
      s0,s1 = a.strides
      m1,n1 = a.shape
      view_shape = (1 + m1 - window[0], 1 + n1 - window[1]) + window
      strides = (s0,s1) + a.strides
      sub_matrices = np.lib.stride_tricks.as_strided(a, view_shape, strides=strides)
      return sub_matrices
  result = sliding_window(a, (2, 2))
