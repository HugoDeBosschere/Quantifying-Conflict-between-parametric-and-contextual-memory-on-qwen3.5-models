import numpy as np

# Define the function to integrate
def integrand(x, y):
    return (np.cos(x))**4 + (np.sin(y))**2

# Create a meshgrid for x and y values
X, Y = np.meshgrid(example_x, example_y)

# Evaluate the function on this grid
Z = integrand(X, Y)

# Define weights for Simpson's rule in 1D
n = len(example_x)
if n % 2 == 0:
    h = (example_x[-1] - example_x[0]) / (n - 1)
    w = np.zeros(n)
    w[0::2] = 1
    w[1:-1:2] = 4
    w[-1] = 1
else:
    h = (example_x[-1] - example_x[0]) / (n - 1)
    w = np.zeros(n)
    w[0::3] = 2
    w[1::3] = 3
    w[2::3] = 4

# Define weights for Simpson's rule in 2D
W = np.outer(w, w)

# Compute the integral using Simpson's rule
integral = h**2 * np.sum(W * Z)
return integral
