import numpy as np

def moving_window(arr, window_shape):
    arr = np.asarray(arr)
    window_shape = np.asarray(window_shape)

    shape = arr.shape[:2]
    strides = arr.strides[:2]

    # Create a sliding window view of the array
    sliding_window_view = np.lib.stride_tricks.as_strided(
        arr, shape=shape + tuple(np.subtract(shape, window_shape) + 1),
        strides=strides * 2)

    return sliding_window_view

