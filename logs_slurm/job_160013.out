def ecdf(x):
    """
    Compute the empirical cumulative distribution function (ECDF) of a sample.

    Args:
        x (array_like): The sample.

    Returns:
        array_like: The ECDF values.
    """
    x = np.sort(x)
    n = len(x)
    y = np.arange(1, n + 1) / n
    return y

def longest_interval(data, threshold):
    """
    Find the longest interval [low, high) that satisfies ECDF(x) < threshold
    for any x in [low, high).

    Args:
        data (array_like): The data.
        threshold (float): The threshold.

    Returns:
        tuple: The longest interval [low, high).
    """
    ecdf_values = ecdf(data)
    n = len(data)
    longest_low = None
    longest_high = None
    max_length = 0
    for i in range(n):
        for j in range(i, n):
            interval_valid = True
            for k in range(i, j + 1):
                if ecdf_values[k] >= threshold:
                    interval_valid = False
                    break
            if interval_valid:
                length = j - i + 1
                if length > max_length:
                    max_length = length
                    longest_low = data[i]
                    longest_high = data[j]
    return (longest_low, longest_high)
(low, high) = longest_interval(grades, threshold)
