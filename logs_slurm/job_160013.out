def trim_array(arr):
    if arr.size == 0:
        return np.array([])
    
    rows = np.any(arr, axis=1)
    cols = np.any(arr, axis=0)
    
    if not np.any(rows):
        return np.array([])
    
    if not np.any(cols):
        return np.array([])
    
    r_start = np.argmax(rows)
    r_end = np.argmax(np.flip(rows))
    c_start = np.argmax(cols)
    c_end = np.argmax(np.flip(cols))
    
    return arr[r_start:r_end+1, c_start:c_end+1]

result = trim_array(im)
