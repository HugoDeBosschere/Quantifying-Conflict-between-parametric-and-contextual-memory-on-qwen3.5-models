```markdown
<code>
def ecdf(data):
    """Compute ECDF for a one-dimensional array of measurements."""
    # Number of data points: n
    n = len(data)
    
    # x-data for the ECDF: x
    x = np.sort_(data)
    
    # y-data for the ECDF: y
    y = np.arange_(1, n+1) / n
    
    return x, y

def evaluate_ecdf(eval_values, ecdf_x, ecdf_y):
    """Evaluate the ECDF at specific values."""
    result = []
    for value in eval_values:
        # Find the index where `value` would be inserted to keep `ecdf_x` sorted
        idx = np.searchsorted_(ecdf_x, value, side='right')
        if idx > 0:
            result.append(ecdf_y[idx - 1])
        else:
            result.append(0.0)
    return np.array_(result)

# Compute ECDF for grades
grades_ecdf_x, grades_ecdf_y = ecdf(grades)

# Evaluate the ECDF at the values in eval
result = evaluate_ecdf(eval, grades_ecdf_x, grades_ecdf_y)
</code>
